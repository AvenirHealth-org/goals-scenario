        <mxCell id="user_py" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;" value="&lt;b&gt;Python API&lt;/b&gt;&lt;br&gt;from avenir_goals_scenario import generate_scenarios, run_scenario_analysis&lt;br&gt;# generate_scenarios takes scenario specification file and outputs scenario descriptor&lt;br&gt;generate_scenarios(&#39;scenario_specification.json&#39;, &quot;scenario_descriptor.json&quot;)&lt;br&gt;# run_scenario_analysis takes scenario_descriptor, applies each scenario to a PJNZ in turn and runs # the model&lt;br&gt;run_scenario_analysis(&quot;pjnz_dir/&quot;, &quot;scenario_descriptor.json&quot;, &quot;output_dir/&quot;)" vertex="1">
